# --- WhatsApp Cloud API (Meta for Developers > WhatsApp > API Setup) ---
WHATSAPP_TOKEN=your_meta_permanent_or_temp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=choose_any_random_string_you_like

# --- Claude API (console.anthropic.com) ---
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-6

# --- Server ---
PORT=3000
TIMEZONE=Asia/Kolkata

# --- Business info (used in agent system prompts) ---
BUSINESS_NAME=Your Medical Books & Journals Co.
BUSINESS_NOTE=We source directly from publishers, no resellers or price comparisons.

# Email customers are told to use for anything urgent, since calls aren't attended.
SUPPORT_EMAIL=csaperiodicals@gmail.com

# --- Reporting schedule (24hr time, in TIMEZONE above) ---
DAILY_REPORT_TIME=20:00

# --- Feedback timing ---
# How many hours after a "dispatched" update to wait before asking the
# customer for delivery/satisfaction feedback.
FEEDBACK_DELAY_HOURS=48

# --- Payments (UPI QR only) ---
# Your UPI ID that customers will pay into, e.g. yourbusiness@okhdfcbank
UPI_VPA=yourbusiness@upi

# --- Inventory ---
# Stock level (per item) at or below which the owner gets a low-stock alert
LOW_STOCK_THRESHOLD=3
